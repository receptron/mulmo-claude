{
  "permissions": {
    "allow": [
      "Bash(yarn lint)",
      "Bash(yarn lint 2>&1 *)",
      "Bash(yarn typecheck)",
      "Bash(yarn typecheck 2>&1 *)",
      "Bash(git fetch *)",
      "Bash(gh run view *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "yarn build:packages && yarn format --check && yarn lint && yarn typecheck && yarn build && yarn test",
            "timeout": 300,
            "statusMessage": "Pre-commit checks (format/lint/typecheck/build/test)..."
          }
        ]
      }
    ]
  }
}
