{
  "name": "@mulmobridge/protocol",
  "version": "0.1.0",
  "description": "Shared types and constants for the MulmoBridge protocol",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/test_*.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "license": "MIT",
  "author": "Receptron Team",
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
